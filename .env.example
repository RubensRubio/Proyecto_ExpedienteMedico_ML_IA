# Variables de entorno para Asistente Clínico
# Copia este archivo a .env y completa los valores

# MongoDB Atlas - Obtener de https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/modelo_pacientes?retryWrites=true&w=majority

# Puerto de desarrollo (en producción usa 8080)
PORT=8000

# Base de datos y colección
DB_NAME=modelo_pacientes
COLLECTION_NAME=coleccion1
